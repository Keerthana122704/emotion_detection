class Solution {
    public ArrayList<Integer> leftView(Node root) {
        // code here
        ArrayList<Integer> res=new ArrayList<>();
        Queue<Node> q=new ArrayDeque<>();
        
        q.add(root);
        while(! q.isEmpty()){
            res.add(q.peek().data);
            int sizee=q.size();
            for(int i=0; i<sizee;i++){
                Node curr=q.poll();
                if(curr.left!=null) q.add(curr.left);
                if(curr.right!=null) q.add(curr.right);
                
            }
        }return res;
    }
}
